{
  "type": "minecraft:disk",
  "config": {
    "half_height": 4,
    "radius": {
      "type": "minecraft:uniform",
      "value": {
        "max_inclusive": 6,
        "min_inclusive": 4
      }
    },
    "state_provider": {
      "fallback": {
        "type": "minecraft:simple_state_provider",
        "state": {
          "Name": "minecraft:dirt"
        }
      },
      "rules": [
        {
          "if_true": {
            "type": "minecraft:all_of",
            "predicates": [
              {
                "type": "minecraft:matching_blocks",
                "offset": [
                  0,
                  1,
                  0
                ],
                "blocks": "minecraft:sand"
              },
              {
                "type": "minecraft:matching_block_tag",
                "offset": [
                  0,
                  -1,
                  0
                ],
                "tag": "minecraft:replaceable"
              }
            ]
          },
          "then": {
            "type": "minecraft:simple_state_provider",
            "state": {
              "Name": "minecraft:sandstone"
            }
          }
        },
        {
          "if_true": {
            "type": "minecraft:matching_blocks",
            "blocks": ["minecraft:water","seagrass","tall_seagrass","ice","sand"],
            "offset": [
              0,
              1,
              0
            ]
          },
          "then": {
            "type": "minecraft:simple_state_provider",
            "state": {
              "Name": "minecraft:sand"
            }
          }
        }
      ]
    },
    "target": {
      "type": "minecraft:matching_blocks",
      "blocks": [
        "minecraft:dirt"
      ]
    }
  }
}